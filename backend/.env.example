APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://127.0.0.1:8000
VOICE_WS_PUBLIC_URL=ws://127.0.0.1:8000/ws/voice/transcribe
VOICE_TOKEN_SECRET=replace-with-a-long-random-secret
VOICE_TOKEN_ISSUER=aarogya-intelligence
VOICE_SESSION_TTL_SECONDS=900
VOICE_MAX_CONCURRENT_SESSIONS=25
VOICE_IDLE_TIMEOUT_SECONDS=20
VOICE_MAX_CHUNK_BYTES=6400
VOICE_TRANSCRIBER_BACKEND=mock
LIQUID_MODEL_ID=LiquidAI/LFM2.5-Audio-1.5B
VOICE_MODEL_DTYPE=auto
# VOICE_API_URL=https://your-transcription-provider.example.com/v1/audio/transcriptions
# VOICE_API_KEY=your-external-transcription-api-key
# VOICE_API_TIMEOUT_SECONDS=30
VOICE_PARTIAL_WINDOW_SECONDS=3.0
VOICE_PARTIAL_STEP_SECONDS=0.5
VOICE_MIN_PARTIAL_SECONDS=0.6
VOICE_MAX_NEW_TOKENS=96

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key

OPENAI_API_KEY=sk-your-openai-key
TAVILY_API_KEY=tvly-your-tavily-key

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-token
DATABRICKS_WAREHOUSE_ID=your-sql-warehouse-id
DATABRICKS_CATALOG=aarogya
DATABRICKS_SCHEMA=default
DATABRICKS_VECTOR_SEARCH_ENDPOINT=your-vector-search-endpoint
DATABRICKS_VECTOR_INDEX=aarogya.default.facilities_scored_index

MLFLOW_TRACKING_URI=databricks
